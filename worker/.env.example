# ── Worker de disparo (Baileys) — copie para .env e ajuste ──────────────────

# Porta da API HTTP consumida pelo painel Next.
WORKER_PORT=8787
# Token simples para proteger a API (recomendado). Vazio = sem proteção.
WORKER_API_TOKEN=

# Cadência humana entre envios (segundos) — aleatório neste intervalo.
WA_MIN_DELAY_SEC=30
WA_MAX_DELAY_SEC=90

# Cota diária de envios POR NÚMERO (proteção anti-ban). Com 2 chips a 40, o
# total seguro é 80/dia — cada número respeita o seu próprio teto.
WA_DAILY_LIMIT=40

# Aquecimento (por número): envios/dia nos primeiros dias, depois usa o limite.
# Ex.: 5,10,20 = 5 no 1º dia, 10 no 2º, 20 no 3º, depois WA_DAILY_LIMIT.
WA_WARMUP_RAMP=5,10,20

# Tentativas por contato antes de marcar falha definitiva.
WA_MAX_ATTEMPTS=3

# ── Números (chips) ─────────────────────────────────────────────────────────
# Vários chips ao mesmo tempo (ex.: celular dual-SIM): liste os telefones de
# pareamento separados por vírgula, formato internacional só dígitos. Cada um
# vira uma sessão com cota/aquecimento próprios e a fila é dividida entre eles.
# Ex.: WA_NUMBERS=5511999990001,5511999990002
WA_NUMBERS=

# Pareamento de UM número só (compat). Se WA_NUMBERS estiver preenchido, isto
# é ignorado. Vazio + WA_NUMBERS vazio = 1 sessão por QR.
WA_PAIR_PHONE=

# DDI padrão para telefones sem código de país (Brasil=55).
WA_DEFAULT_DDI=55

# URL do painel (que tem as chaves Google/Instagram) — usada pelo AGENDADOR
# para rodar a busca sozinho. No Pi/Render o painel é local.
PANEL_URL=http://localhost:3000

# ── Anti-ban ────────────────────────────────────────────────────────────────
# Janela de horário de envio (hora local). Ex.: 9-19 só envia das 9h às 19h.
# Vazio = 24h. Evita parecer robô de madrugada.
WA_SEND_WINDOW=9-19

# Teto de envios por HORA, por número (0 = sem teto). Suaviza picos.
WA_MAX_PER_HOUR=0

# Não recontatar o mesmo número entre campanhas por N dias (0 = sempre pode).
# Ex.: 30 = pula quem já recebeu nos últimos 30 dias, em qualquer campanha.
WA_RECONTACT_DAYS=0

# Variação de mensagem (spintax): use {opção1|opção2|...} no texto — cada
# destinatário recebe uma variação sorteada. Ex.: "{Oi|Olá|Opa} {nome}!".
# (Não precisa de env; é escrito direto na mensagem no painel.)

# Opt-out: palavras que, recebidas do contato, o removem da lista.
WA_OPTOUT_KEYWORDS=sair,parar,pare,cancelar,stop,descadastrar,remover
# Rodapé opcional anexado a toda mensagem. Vazio = não anexa.
# Ex.: WA_OPTOUT_FOOTER=Responda SAIR para não receber.
WA_OPTOUT_FOOTER=

# Nível de log do Baileys (silent|error|warn|info|debug).
WA_LOG_LEVEL=silent

# Caminhos de dados (padrão: ./data). Descomente para customizar.
# WORKER_DATA_DIR=./data
# WORKER_AUTH_DIR=./data/auth
# WORKER_DB_PATH=./data/worker.db
