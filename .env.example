# Painel privado — obrigatórias. A senha deve ter ao menos 6 caracteres.
PANEL_ADMIN_EMAIL=
PANEL_ADMIN_PASSWORD=
# Gere com: openssl rand -hex 32
PANEL_SESSION_SECRET=

# Comunicação servidor-servidor com o worker.
WORKER_URL=http://localhost:8787
