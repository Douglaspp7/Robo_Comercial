# Atendente Zapien dedicado.
ATTENDANT_URL=http://localhost:3001

# Fontes/canais opcionais.
GOOGLE_PLACES_API_KEY=
IG_ACCESS_TOKEN=
IG_BUSINESS_ID=
SMTP_EMAIL=
SMTP_PASSWORD=
