# Raspberry em rede doméstica/Tailscale: use 1. Nunca use em internet pública.
PANEL_AUTH_DISABLED=0

# Obrigatórias quando PANEL_AUTH_DISABLED não for 1.
PANEL_ADMIN_EMAIL=
PANEL_ADMIN_PASSWORD=
# Gere com: openssl rand -hex 32
PANEL_SESSION_SECRET=

# Comunicação servidor-servidor com o worker.
WORKER_URL=http://localhost:8787
WORKER_API_TOKEN=

# Atendente Zapien dedicado.
ATTENDANT_URL=http://localhost:3001

# Fontes/canais opcionais.
GOOGLE_PLACES_API_KEY=
IG_ACCESS_TOKEN=
IG_BUSINESS_ID=
SMTP_EMAIL=
SMTP_PASSWORD=
