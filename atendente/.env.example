# ============================================================
# Configuracao da PLATAFORMA Zapien (nivel do servidor)
# Copie este arquivo para ".env" e preencha.
# As configuracoes de cada CLIENTE (negocio, WhatsApp, checkout)
# sao feitas pelo painel web, nao aqui.
#
# Valide sua configuracao com:
#   npm run validate:config              (validacao estrutural, sem credenciais)
#   npm run validate:config:production   (validacao completa para deploy)
# ============================================================

# ------------------------------------------------------------
# OBRIGATORIAS EM PRODUCAO
# ------------------------------------------------------------

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# Token que VOCE inventa e usa tambem ao cadastrar o webhook na Meta.
WHATSAPP_VERIFY_TOKEN=

# Segredo para assinar os cookies de sessao. Use um valor aleatorio longo.
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Chave de criptografia AES-256 para tokens armazenados no banco
# (wa_token, mp_access_token, etc.). 64 caracteres hex (32 bytes).
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AVISO: se mudar esta chave, todos os tokens existentes precisarao ser re-salvos.
DATA_ENCRYPTION_KEY=

# ------------------------------------------------------------
# NECESSARIAS PARA O WHATSAPP DA PLATAFORMA
# Um unico numero WhatsApp atende todos os lojistas via roteamento por slug.
# ------------------------------------------------------------

# Phone Number ID do Meta Cloud API
# (developers.facebook.com > seu app > WhatsApp > Configuracao).
WA_PHONE_NUMBER_ID=
# Token de acesso permanente do Meta (System User Token com permissao
# whatsapp_business_messaging).
WA_TOKEN=
# Numero real do WhatsApp no formato E.164 sem "+" (ex: 5511999990000).
# Usado para gerar o link wa.me que os lojistas compartilham com seus clientes
# e para enviar o cartao vCard "Adicionar aos contatos" na primeira mensagem.
WA_SERVER_PHONE=

# ------------------------------------------------------------
# SERVIDOR E BANCO
# ------------------------------------------------------------

PORT=3000
# URL publica onde a aplicacao esta hospedada. Ex: https://zapien.app
APP_URL=http://localhost:3000

# Caminho do banco SQLite.
# No Render, use o disco persistente. Ex: DATABASE_PATH=/var/data/zapien.db
# (instalacoes antigas podem manter o caminho legado ja existente no disco).
DATABASE_PATH=./data/zapien.db

# Modelo do Claude. Padrao: claude-haiku-4-5 (o mais rapido e economico,
# ideal para vendas em volume). Para respostas mais elaboradas: claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-haiku-4-5
WHATSAPP_API_VERSION=v21.0

# ------------------------------------------------------------
# SEGURANCA (opcionais recomendadas)
# ------------------------------------------------------------

# Segredo adicional para tokens CSRF (se omitido, usa SESSION_SECRET).
# Recomendado em producao para separar os segredos.
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
CSRF_SECRET=

# Segredo para assinar URLs de midia/catalogo servidas ao WhatsApp
# (se omitido, usa SESSION_SECRET). Recomendado em producao.
MEDIA_URL_SECRET=

# ------------------------------------------------------------
# RECUPERACAO DE SENHA
# ------------------------------------------------------------

# Como enviar o link de "esqueci minha senha":
#   console = imprime o link no log do servidor (somente desenvolvimento)
#   off     = nao imprime nem envia (util em teste automatizado)
#   resend  = envia e-mail real via Resend (obrigatorio em producao)
# Em producao, "console" e recusado pela validacao de configuracao.
# O endpoint /api/forgot-password sempre responde "se o e-mail existir,
# enviamos um link" para nao virar oraculo de contas.
RESET_EMAIL_SENDER=console

# Chave da API do Resend (resend.com) — obrigatoria quando RESET_EMAIL_SENDER=resend.
RESEND_API_KEY=
# Remetente dos e-mails transacionais (dominio verificado no Resend).
EMAIL_FROM=Zapien <acesso@zapien.app>
# E-mail de suporte exibido no rodape do e-mail de redefinicao (opcional).
SUPPORT_EMAIL=

# ------------------------------------------------------------
# ADMINISTRADOR E SUPORTE (opcionais recomendadas)
# ------------------------------------------------------------

# A conta criada com este e-mail vira admin (acessa /admin.html).
ADMIN_EMAIL=

# Numero WhatsApp do suporte (formato internacional sem +, ex: 5511999990000).
# Exibido para clientes que clicam em "Suporte" na tela de configuracoes.
SUPPORT_PHONE=

# --- Alertas operacionais (recomendado) ---
# Numero de WhatsApp (formato internacional sem +) que recebe alertas:
# fila sobrecarregada, credito da IA/OpenAI esgotado, pagamento Meta.
# Se omitido, usa SUPPORT_PHONE. Sem nenhum dos dois, os alertas so vao para o log.
ALERT_PHONE=
# Minutos de silencio entre alertas repetidos do mesmo tipo (evita spam). Padrao 30.
ALERT_COOLDOWN_MIN=30
# Tamanho da fila de IA que dispara alerta de saturacao. Padrao 50.
QUEUE_ALERT_THRESHOLD=50

# ------------------------------------------------------------
# ESCALA (opcionais)
# ------------------------------------------------------------

# Quantas respostas de IA processar em paralelo (protege o limite da Anthropic).
AI_CONCURRENCY=5
# Limites da fila de IA (justa por tenant, em memoria). Quando um limite e
# atingido o job e recusado com registro/alerta e o turno fica marcado para a
# varredura de recuperacao — nada se perde em silencio.
AI_QUEUE_MAX_GLOBAL=500
AI_QUEUE_MAX_PER_TENANT=50
# Espera considerada critica (ms) — acima disso o monitor dispara alerta.
AI_QUEUE_MAX_WAIT_MS=120000

# Fila persistente de disparos em massa (campanhas, avisos de reposicao) —
# ver src/outbound-queue.js. Vive no SQLite; sobrevive a reinicio. O worker
# processa em background enquanto a rota HTTP responde 202 imediatamente.
OUTBOUND_CONCURRENCY=3
OUTBOUND_MAX_PER_TENANT=1
OUTBOUND_MIN_INTERVAL_MS=500
OUTBOUND_MAX_ATTEMPTS=5
OUTBOUND_LOCK_TIMEOUT_MS=120000
OUTBOUND_RETRY_BASE_MS=5000
OUTBOUND_POLL_INTERVAL_MS=1000
# Tempo de espera (ms) para juntar mensagens rapidas do mesmo contato.
DEBOUNCE_MS=3000

# --- Central de Saude da Meta (verificacao periodica da conexao WhatsApp) ---
# Verifica token/numero/templates na Graph API e mantem o snapshot que a tela
# "Saude do WhatsApp" (Integracoes) exibe. Desligue com META_HEALTH_ENABLED=false.
META_HEALTH_ENABLED=true
META_HEALTH_INTERVAL_MS=900000
META_HEALTH_CONCURRENCY=2
META_HEALTH_TIMEOUT_MS=10000
# Cooldown (min) do push "conexao critica" — novo push antes disso so se o
# codigo do problema mudar ou se o problema resolver e voltar. Padrao 360 (6h).
META_CRITICAL_PUSH_COOLDOWN_MIN=360
# WABA ID (WhatsApp Business Account) da plataforma — opcional; habilita a
# contagem de templates aprovados/pendentes/rejeitados quando a Graph API
# nao expoe o WABA a partir do numero.
META_WABA_ID=

# --- Automacoes comerciais (QUANDO -> SE -> ENTAO) ---
# Worker persistente (SQLite) que executa as automacoes criadas no painel.
# Desligue com AUTOMATIONS_ENABLED=false (eventos deixam de agendar jobs).
AUTOMATIONS_ENABLED=true
AUTOMATION_CONCURRENCY=3
AUTOMATION_MAX_PER_TENANT=1
AUTOMATION_MAX_ATTEMPTS=5
AUTOMATION_LOCK_TIMEOUT_MS=120000
AUTOMATION_POLL_INTERVAL_MS=1000
# Profundidade maxima de encadeamento (automacao dispara evento que dispara
# outra automacao...) — protecao contra loops. Padrao 3.
AUTOMATION_MAX_CHAIN_DEPTH=3

# --- Limites de IA (protecao contra abuso) ---
# Tokens maximos por resposta, chamadas por contato/tenant etc. sao definidos
# POR PLANO (ver src/plans.js) — nao ha variaveis globais para isso.
# Minutos que um contato fica silenciado apos mensagens fora do escopo.
AI_OFF_TOPIC_MUTE_MINUTES=30

# ============================================================
# OPCIONAIS — habilitam recursos extras quando preenchidos.
# Sem eles, o app funciona (sem cobranca, sem 1-clique, sem audio).
# ============================================================

# --- Stripe (assinaturas — alternativa, desligado por padrao) ---
# Sem estes, o billing Stripe fica desativado.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
# Dias de teste gratuito antes de exigir assinatura.
# Deve ficar alinhado com a promessa da landing ("7 dias gratis, sem cartao").
TRIAL_DAYS=7

# --- Mercado Pago (assinaturas recorrentes — alternativa ao Stripe) ---
# Token da sua conta de plataforma MP (diferente do token do cliente).
MP_PLATFORM_TOKEN=
MP_WEBHOOK_SECRET=

# --- Mercado Pago OAuth (conectar conta do lojista com 1 clique) ---
# Obtenha em mercadopago.com.br/developers > Suas aplicacoes > Credenciais.
MP_OAUTH_APP_ID=
MP_OAUTH_APP_SECRET=

# --- Meta Embedded Signup (conectar WhatsApp com 1 clique) ---
# Se nao preencher META_APP_SECRET, a validacao de assinatura do webhook e desabilitada.
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=

# --- OpenAI (transcricao de audio e configuracao por voz) ---
OPENAI_API_KEY=

# --- Web Push (notificacoes no celular/desktop via PWA) ---
# Sem as chaves VAPID, o painel funciona normalmente e o push fica desativado.
# Gere o par com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contato do responsavel (exigido pelo protocolo Web Push).
VAPID_SUBJECT=mailto:contato@zapien.app
# Override explicito: "false" desliga o push mesmo com chaves preenchidas.
WEB_PUSH_ENABLED=

# --- Google Sheets (planilha automatica por lojista) ---
# Configure no Google Cloud Console e autorize o redirect
# /api/google-sheets/oauth/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Opcional: se vazio, usa APP_URL + /api/google-sheets/oauth/callback.
GOOGLE_OAUTH_REDIRECT_URI=
# Login social com Google (mesmo Client ID/Secret acima).
# Adicione https://zapien.app/api/auth/google/callback nos Redirect URIs do Google Cloud Console.
# Opcional: se vazio, usa APP_URL + /api/auth/google/callback.
GOOGLE_LOGIN_REDIRECT_URI=

# --- Melhor Envio (frete para lojistas Elite via token da plataforma) ---
# Em melhorenvio.com.br > Configuracoes > Tokens (permissao: shipping.calculate).
MELHOR_ENVIO_PLATFORM_TOKEN=

# --- Bling ERP (OAuth2 — sincroniza produtos/estoque, emite NF) ---
# Obtenha em bling.com.br > Aplicativos > (seu app) > Client ID/Secret.
BLING_OAUTH_CLIENT_ID=
BLING_OAUTH_CLIENT_SECRET=

# --- Nuvemshop (OAuth2 — sincroniza produtos/estoque) ---
NUVEMSHOP_CLIENT_ID=
NUVEMSHOP_CLIENT_SECRET=

# --- Tray (OAuth2 — sincroniza produtos/estoque; modulo pronto, UI desativada) ---
TRAY_CLIENT_ID=
TRAY_CLIENT_SECRET=

# --- Uploads ---
# Diretorio temporario dos uploads (padrao: os.tmpdir()/zapien-uploads).
UPLOAD_TMP_DIR=
# Uploads simultaneos maximos (acima disso responde 503 + Retry-After).
UPLOAD_MAX_CONCURRENT=3
# Idade maxima (minutos) de temporarios orfaos antes da varredura remover.
UPLOAD_TMP_MAX_AGE_MIN=60

# --- Backup ---
# Diretorio onde os backups sao armazenados (npm run backup).
BACKUP_DIR=./data/backups
# Quantos dias manter os backups antes de expurgar.
BACKUP_RETAIN_DAYS=30

# --- Retencao de midia ---
# Fotos/audios/videos/PDFs trocados no chat sao BLOBs no banco e sao expurgados
# automaticamente para nao esgotar o disco. O prazo e POR PLANO (ver
# src/plans.js) — nao ha variavel de ambiente global para isso.
